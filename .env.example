# ==============================================================================
# Project VERA — Environment Variables
# ==============================================================================
# Copy this file to .env and fill in your credentials.
# ==============================================================================

# --- LLM Backend Selection ---
# Options: GEMINI, GROQ, OLLAMA
LLM_BACKEND=OLLAMA

# --- Retrieval Mode ---
# FAST = direct retrieval (fewer LLM calls, ~3 calls, best for Ollama)
# DEEP = multi-query + reranking (exhaustive, ~9 calls, best for Gemini/Groq)
RETRIEVAL_MODE=fast

# --- LLM Model Name (optional override) ---
# If not set, defaults are used per backend:
#   GEMINI  → gemini-2.0-flash
#   GROQ    → llama-3.3-70b-versatile
#   OLLAMA  → (see OLLAMA_MODEL below)
LLM_MODEL_NAME=

# --- Embedding Model Type ---
# Options: GEMINI, HUGGINGFACE, OLLAMA
# If not set, embedding type follows LLM_BACKEND (Gemini→Gemini, rest→Ollama)
EMBEDDING_MODEL_TYPE=

# --- Google Gemini API ---
GOOGLE_API_KEY=
# Legacy alias (also accepted):
# GEMINI_API_KEY=

# --- Groq API (high-speed inference) ---
GROQ_API_KEY=

# --- Ollama Settings (local models) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=hf.co/bartowski/Llama-3.2-1B-Instruct-GGUF
OLLAMA_EMBED_MODEL=hf.co/CompendiumLabs/bge-base-en-v1.5-gguf

# --- Email Alerting (Escalation Notifications) ---
# Gmail App Password: https://support.google.com/accounts/answer/185833
SENDER_EMAIL=
EMAIL_APP_PASSWORD=
# Comma-separated list of recipients for all alert emails
EMAIL_RECIPIENTS=safety-team@example.com,manager@example.com
